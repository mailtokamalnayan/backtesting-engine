# Copy to .env and fill in. .env is gitignored — never commit real values.

# Zerodha Kite Connect — only needed for intraday (minute) strategies.
# Create an app at https://developers.kite.trade/ (redirect URL http://127.0.0.1)
# and enable the historical-data add-on. Daily strategies need none of this.
KITE_API_KEY=
KITE_API_SECRET=

# Vercel target for `make publish` — only needed if you host the static site.
# VERCEL_SCOPE is your Vercel team/account slug; VERCEL_ALIAS is the clean
# *.vercel.app alias to re-point after each prod deploy. Both optional: with no
# scope the deploy uses your default; with no alias the alias step is skipped.
VERCEL_SCOPE=
VERCEL_ALIAS=
